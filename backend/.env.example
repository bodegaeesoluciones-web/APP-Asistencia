# Variables de entorno — Backend

# === Base de datos ===
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# === JWT ===
JWT_SECRET=cambia_este_secreto_muy_largo_y_seguro_123
JWT_REFRESH_SECRET=otro_secreto_diferente_para_refresh_456
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# === Servidor ===
PORT=3000
NODE_ENV=development

# === Configuración de asistencia ===
BASE_LAT=-12.0464
BASE_LNG=-77.0428
ALLOWED_RADIUS_M=50
AUTHORIZED_SSID=EESOLUCIONES_BASE
QR_ROTATION_MINUTES=60
TIMEZONE=America/Lima
LATE_HOUR=8
LATE_MINUTE=0

# === CORS ===
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

# === Dropbox (Evidencia Fotográfica) ===
# Token de acceso a Dropbox (genera uno en https://www.dropbox.com/developers/apps)
DROPBOX_ACCESS_TOKEN=tu_token_de_dropbox_aqui

